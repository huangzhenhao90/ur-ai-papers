# MiniMax API（OpenAI 兼容接口，用于 LLM 双打分 + 中文标题 + TL;DR）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5-lightning

# 联系邮箱（OpenAlex / Crossref / Unpaywall 都建议在 User-Agent 标识）
CONTACT_EMAIL=your_email@example.com

# 数据库路径
DB_PATH=./data/papers.db

# 增量更新配置（可选）
LOOKBACK_DAYS=14
LLM_SAFETY_LIMIT=500
